rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers base ──────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymous() {
      return request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isStaff() {
      return isSignedIn() && !isAnonymous();
    }

    // ─── Perfil del usuario autenticado ────────────────────────────────────────

    function userRef() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function userExists() {
      return isStaff() && exists(userRef());
    }

    function userDoc() {
      return get(userRef()).data;
    }

    // Usuario con estado "active" en su perfil
    function isActive() {
      return userExists() && userDoc().get('status', 'pending') == 'active';
    }

    // Usuario con un rol específico en su array de roles
    function hasRole(role) {
      return userExists() && userDoc().get('roles', []).hasAny([role]);
    }

    // ─── Admin ─────────────────────────────────────────────────────────────────

    // Admin por email del token (propietario del sistema, siempre activo)
    function isAdminEmail() {
      return isStaff() && request.auth.token.email == 'gerenciacchainservices@gmail.com';
    }

    // Admin por rol en el perfil
    function hasAdminRole() {
      return userExists() && userDoc().get('roles', []).hasAny(['admin']);
    }

    function isAdmin() {
      return isAdminEmail() || (isStaff() && hasAdminRole());
    }

    // ─── Usuario activo (no pendiente) ─────────────────────────────────────────
    // Cualquier staff activo o el admin-email (que no necesita perfil en DB)

    function isActiveStaff() {
      return isAdmin() || (isStaff() && isActive());
    }

    // ─── Cotizaciones ──────────────────────────────────────────────────────────
    match /cotizaciones/{cotId} {
      allow read: if isActiveStaff() && (
        isAdmin() ||
        ('uid' in resource.data && resource.data.uid == request.auth.uid) ||
        !('uid' in resource.data)
      );
      allow create: if isActiveStaff() && (
        !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid
      );
      allow update, delete: if isActiveStaff() && (
        isAdmin() ||
        ('uid' in resource.data && resource.data.uid == request.auth.uid)
      );
    }

    // ─── Perfiles de usuario ───────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Lectura: el propio usuario puede ver su perfil (para saber si está pendiente)
      allow read: if isStaff() && (request.auth.uid == uid || isAdmin());
      allow create: if isStaff() && (request.auth.uid == uid || isAdmin());
      allow update: if isStaff() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Índice por email
    match /usuarios_email/{emailKey} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // ─── Empresas y Contactos ──────────────────────────────────────────────────
    match /empresas/{empresaId} {
      allow read: if isActiveStaff();
      allow create, update: if isActiveStaff();
      allow delete: if isAdmin();

      match /contactos/{contactoId} {
        allow read: if isActiveStaff();
        allow create, update: if isActiveStaff();
        allow delete: if isAdmin();
      }
    }

    // ─── Contadores de numeración ──────────────────────────────────────────────
    match /counters/{counterId} {
      allow read: if isActiveStaff();
      allow write: if isActiveStaff();
    }

    match /quoteCounters/{docId} {
      allow read: if isActiveStaff();
      allow write: if isActiveStaff();
    }

    // ─── Producción: admin o usuario con rol "produccion" ──────────────────────
    match /produccion/{docId} {
      allow read, write: if isAdmin() || (isActiveStaff() && hasRole('produccion'));
    }

    match /produccion/{docId}/{subCol}/{subId} {
      allow read, write: if isAdmin() || (isActiveStaff() && hasRole('produccion'));
    }

    // ─── Inventario: admin o usuario con rol "inventario" ─────────────────────
    match /inventario/{docId} {
      allow read, write: if isAdmin() || (isActiveStaff() && hasRole('inventario'));
    }

    match /inventario/{docId}/{subCol}/{subId} {
      allow read, write: if isAdmin() || (isActiveStaff() && hasRole('inventario'));
    }

    // ─── Configuración de precios ──────────────────────────────────────────────
    match /pricingConfig/{docId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /configuracion/{docId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    // ─── Catálogo de productos ────────────────────────────────────────────────
    match /productos/{docId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    // ─── Catch-all: admin accede a todo; todo lo demás denegado ───────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
