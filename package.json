{
  "name": "cotizador-app",
  "version": "1.1.2",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "vite:dev": "vite --port 5174 --strictPort",
    "dev:desktop": "concurrently -k \"npm run vite:dev\" \"npm run electron:wait\"",
    "electron:wait": "wait-on http://localhost:5174 && npm run electron:dev",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5174 electron .",
    "build": "vite build",
    "build:public": "cross-env VITE_REQUIRE_LOGIN=false VITE_ENABLE_PRODUCCION=false VITE_ENABLE_INVENTARIO=false vite build",
    "electron:prod": "npm run build && electron .",
    "build:desktop": "vite build && electron-builder --win",
    "build:desktop:public": "cross-env VITE_REQUIRE_LOGIN=false VITE_ENABLE_PRODUCCION=false VITE_ENABLE_INVENTARIO=false vite build && electron-builder --win",
    "android:build": "npm run build && npx cap sync android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run android:build && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@react-pdf/renderer": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "firebase": "^12.0.0",
    "html-react-parser": "^5.2.6",
    "html2pdf.js": "^0.10.3",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.6.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ccs.cotizador",
    "productName": "Cotizador",
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "C:\\Users\\danma\\OneDrive\\LUZ AMPARO\\release\\release"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
