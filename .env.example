# Firebase (client config) — copia este archivo como .env y completa los valores
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Seguridad — mantener en true en producción
VITE_REQUIRE_LOGIN=true
VITE_ANON_AUTH=false

# Email del administrador principal (acceso total + módulo Producción)
VITE_ADMIN_EMAIL=

# Email que se promueve a admin en el primer inicio de sesión
VITE_BOOTSTRAP_ADMIN_EMAIL=

# Módulos opcionales
VITE_ENABLE_PRODUCCION=true
VITE_ENABLE_INVENTARIO=true
