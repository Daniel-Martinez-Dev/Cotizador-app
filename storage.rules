rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /productos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == 'gerenciacchainservices@gmail.com';
    }
    // Bundles de actualización OTA — lectura pública, escritura solo admin SDK
    match /updates/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
